rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'DxTnrg4cG4TWHK6qkbSZudfzJgh2';
    }

    function isSupportInboxOwner(adminUid) {
      return adminUid == 'DxTnrg4cG4TWHK6qkbSZudfzJgh2';
    }

    function isValidSupportMessage(adminUid) {
      return isSignedIn()
        && isSupportInboxOwner(adminUid)
        && request.resource.data.adminUid == adminUid
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 3
        && request.resource.data.message.size() <= 900
        && request.resource.data.topic in ['feedback', 'difficulty', 'bug', 'idea']
        && request.resource.data.status == 'new';
    }

    function roomHasPlayer(data, uid) {
      return uid != null && (
        data.players.player1.uid == uid ||
        data.players.player2.uid == uid
      );
    }

    function roomHasPartyPlayer(data, uid) {
      return uid != null
        && data.players is list
        && (
          (data.players.size() > 0 && data.players[0].uid == uid) ||
          (data.players.size() > 1 && data.players[1].uid == uid) ||
          (data.players.size() > 2 && data.players[2].uid == uid) ||
          (data.players.size() > 3 && data.players[3].uid == uid)
        );
    }

    function isDuelRoom(data) {
      return data.roomType == 'duel';
    }

    function isPartyRoom(data) {
      return data.roomType == 'party';
    }

    function isRoomParticipant(data) {
      return isSignedIn() && (
        (isDuelRoom(data) && roomHasPlayer(data, request.auth.uid)) ||
        (isPartyRoom(data) && roomHasPartyPlayer(data, request.auth.uid))
      );
    }

    function isValidDuelCreate(roomCode) {
      return request.resource.data.roomCode == roomCode
        && request.resource.data.roomType == 'duel'
        && request.resource.data.gameMode == 'online_1v1'
        && request.resource.data.status == 'waiting'
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.winnerUid == null
        && request.resource.data.letterCount is number
        && request.resource.data.challenge is map
        && request.resource.data.challenge.word is string
        && request.resource.data.players.player1.uid == request.auth.uid
        && request.resource.data.players.player2.uid == null;
    }

    function isValidPartyCreate(roomCode) {
      return request.resource.data.roomCode == roomCode
        && request.resource.data.roomType == 'party'
        && request.resource.data.gameMode == 'online_party'
        && request.resource.data.status == 'waiting'
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.winnerUid == null
        && request.resource.data.maxPlayers == 4
        && request.resource.data.letterCount is number
        && request.resource.data.word is string
        && request.resource.data.challenge is map
        && request.resource.data.challenge.word is string
        && request.resource.data.players is list
        && request.resource.data.players.size() == 1
        && request.resource.data.players[0].uid == request.auth.uid;
    }

    function isValidDuelUpdate() {
      return request.resource.data.roomCode == resource.data.roomCode
        && request.resource.data.roomType == resource.data.roomType
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.gameMode == resource.data.gameMode
        && request.resource.data.letterCount == resource.data.letterCount
        && request.resource.data.challenge == resource.data.challenge
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          isRoomParticipant(resource.data) ||
          (
            resource.data.status == 'waiting' &&
            resource.data.players.player2.uid == null &&
            request.resource.data.players.player2.uid == request.auth.uid
          )
        );
    }

    function isValidPartyJoin() {
      return resource.data.status == 'waiting'
        && resource.data.players is list
        && request.resource.data.players is list
        && resource.data.players.size() < resource.data.maxPlayers
        && request.resource.data.players.size() == resource.data.players.size() + 1
        && request.resource.data.players[resource.data.players.size()].uid == request.auth.uid;
    }

    function isValidPartyUpdate() {
      return request.resource.data.roomCode == resource.data.roomCode
        && request.resource.data.roomType == resource.data.roomType
        && request.resource.data.hostUid is string
        && request.resource.data.gameMode == resource.data.gameMode
        && request.resource.data.maxPlayers == resource.data.maxPlayers
        && request.resource.data.letterCount == resource.data.letterCount
        && request.resource.data.word == resource.data.word
        && request.resource.data.challenge == resource.data.challenge
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.players is list
        && request.resource.data.players.size() <= request.resource.data.maxPlayers
        && (
          isRoomParticipant(resource.data) ||
          isValidPartyJoin()
        );
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /daily_word_pool/{wordId} {
      allow read: if true;
    }

    match /daily_words/{dateKey} {
      allow read: if true;
    }

    match /daily_leaderboard/{dateKey} {
      allow read: if true;
    }

    match /rooms/{roomCode} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isSignedIn()
        && !exists(/databases/$(database)/documents/rooms/$(roomCode))
        && (
          isValidDuelCreate(roomCode) ||
          isValidPartyCreate(roomCode)
        );

      allow update: if isSignedIn()
        && (
          (isDuelRoom(resource.data) && isValidDuelUpdate()) ||
          (isPartyRoom(resource.data) && isValidPartyUpdate())
        );

      allow delete: if false;
    }

    match /matchmaking/{queueId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /supportMessages/{adminUid}/inbox/{messageId} {
      allow create: if isValidSupportMessage(adminUid);
      allow get, list, update, delete: if isAdmin() && isSupportInboxOwner(adminUid);
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
